{
  "expo": {
    "name": "Chaplin",
    "slug": "chaplin",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chaplin",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.projectchaplin.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.projectchaplin.app",
      "adaptiveIcon": {
        "backgroundColor": "#120D18",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#120D18",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Chaplin uses your selected image to establish your actor's visual identity.",
          "cameraPermission": "Chaplin uses the camera when you choose to capture an actor reference.",
          "microphonePermission": false
        }
      ],
      "expo-secure-store",
      "expo-audio",
      "expo-video",
      "expo-sharing",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
